---
import type { Student } from "../data/students";
const { student } = Astro.props as { student: Student };
---

<a
  href={`/${student.slug}/`}
  class="block border border-(--border-color) rounded-lg p-6 space-y-3 hover:border-(--accent-cyan) transition-colors bg-(--bg-secondary)"
>
  <div class="w-16 h-16 rounded-full bg-(--border-color) flex items-center justify-center text-2xl font-bold text-(--accent-green)">
    {student.name.charAt(0)}
  </div>
  <h3 class="text-xl font-bold text-(--text-primary)">{student.name}</h3>
  <p class="text-sm text-(--accent-cyan)">{student.role}</p>
  <p class="text-sm text-(--text-secondary)">{student.description}</p>
  <span class="inline-flex items-center gap-1 text-xs text-(--accent-green) font-medium">
    Ver portafolio →
  </span>
</a>
