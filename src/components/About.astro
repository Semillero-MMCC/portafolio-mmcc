---
import {Image} from 'astro:assets';
import aboutMeImg from '../assets/images/aboutMeImg.png'

const {
  bio = "",
  aboutImgAlt = "Sobre mí",
  yearsExperience = "1+",
  projectsCompleted = "5+",
} = Astro.props;
---
<section id="about" class="border-b border-(--border-color)">
  <div class="max-w-7xl mx-auto px-6 py-12 md:py-26">
    <header class="mb-8 md:hidden">
      <h2>Sobre mí</h2>
    </header>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-center">
      <div class="order-1 md:order-1">
        <div class="aspect-square rounded-2xl overflow-hidden bg-(--bg-secondary)">
          <Image
            src={aboutMeImg}
            alt={aboutImgAlt}
            class="w-full h-full object-cover"
            width={600}
            height={600}
            loading="lazy"
          />
        </div>
      </div>

      <div class="order-2 md:order-2 space-y-8">
        <header class="hidden md:block">
          <h2>Sobre mí</h2>
        </header>

        <div class="space-y-4 whitespace-pre-line">
          <p>{bio}</p>
        </div>

        <aside class="grid grid-cols-2 gap-4">
          <div class="border border-(--border-color) rounded-lg p-6 text-center space-y-2 transition-transform duration-300 hover:-translate-y-2">
            <p class="text-4xl font-bold text-(--accent-green)">{yearsExperience}</p>
            <p class="text-sm text-(--text-secondary)">Años de experiencia</p>
          </div>
          <div class="border border-(--border-color) rounded-lg p-6 text-center space-y-2 transition-transform duration-300 hover:-translate-y-2">
            <p class="text-4xl font-bold text-(--accent-cyan)">{projectsCompleted}</p>
            <p class="text-sm text-(--text-secondary)">Proyectos completados</p>
          </div>
        </aside>
      </div>
    </div>
  </div>
</section>
